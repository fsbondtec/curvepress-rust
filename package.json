{
  "name": "curvepress",
  "version": "0.2.0",
  "description": "Lossy time series compression: RDP/VW point reduction + quantization",
  "license": "MIT",
  "main": "./pkg/curvepress.js",
  "types": "./wasm/curvepress.d.ts",
  "files": ["pkg/", "wasm/"],
  "scripts": {
    "build": "wasm-pack build --target bundler --features wasm",
    "build:node": "wasm-pack build --target nodejs --out-dir pkg-node --features wasm",
    "test": "node tests/wasm/test_wasm.mjs"
  },
  "keywords": ["compression", "time-series", "wasm", "rdp", "visvalingam"],
  "repository": {
    "type": "git",
    "url": "https://github.com/fsbondtec/curvepress-rust"
  }
}
